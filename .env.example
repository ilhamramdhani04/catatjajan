# ─── Database (Supabase PostgreSQL) ──────────────────────────
# Dari: Supabase Dashboard → Settings → Database → Connection String
#
# DATABASE_URL  → Transaction Pooler (port 6543) — dipakai Next.js runtime
# DIRECT_URL    → Direct Connection (port 5432)  — dipakai drizzle-kit migrate
#
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ─── Better Auth ────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Meta WhatsApp Cloud API ────────────────────────────────
# Dari Meta Developer Console → WhatsApp → API Setup
WA_PHONE_NUMBER_ID="your-phone-number-id"
WA_ACCESS_TOKEN="your-permanent-access-token"
WA_WEBHOOK_VERIFY_TOKEN="your-random-verify-token"

# ─── Cron Jobs ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"

# ─── Web Push (VAPID) ─────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_SUBJECT="mailto:admin@yourdomain.com"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
