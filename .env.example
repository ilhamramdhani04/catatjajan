# ─── Database ───────────────────────────────────────────────
# Path ke file SQLite lokal
DATABASE_URL="postgresql://postgres.vbepcyzgqvpfkcdbyxis:[@Subaru04122002@]]@aws-1-..."
DIRECT_URL="postgresql://postgres.vbepcyzgqvpfkcdbyxis:[@Subaru04122002@]@aws-1-..."

# ─── Better Auth ────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Meta WhatsApp Cloud API ────────────────────────────────
# Dari Meta Developer Console → WhatsApp → API Setup
WA_PHONE_NUMBER_ID="your-phone-number-id"
WA_ACCESS_TOKEN="your-permanent-access-token"
WA_WEBHOOK_VERIFY_TOKEN="your-random-verify-token"

# ─── Cron Jobs ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Dipakai sebagai Bearer token di header Authorization untuk /api/cron
CRON_SECRET="your-cron-secret-here"

# ─── Web Push (VAPID) ─────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_SUBJECT="mailto:admin@yourdomain.com"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
# Public key juga harus tersedia di client-side
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
